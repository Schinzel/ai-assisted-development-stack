hs_err_pid*
replay_pid*

# IntelliJ IDEA
.idea/*
!.idea/codeStyles/          # Code formatting rules
!.idea/scopes/              # Custom scopes for inspections
!.idea/dictionaries/        # Project-level dictionary words
!.idea/spelling.xml         # Spellchecker config (points to config/poak.dic)
!.idea/inspectionProfiles/  # Inspection settings
*.iml
*.ipr
*.iws
out/

# macOS
.DS_Store

# MCP Serena
.serena/

# Eclipse JDT.LS (jdtls). A plugin to Claude Code
.classpath
.factorypath
.project
.settings/

# Maven
target/

# Generated by Maven Shade plugin
dependency-reduced-pom.xml

# JTE generated files
jte-classes/
# Vim swap files
*.swp

# Playwright screenshots
.playwright-mcp/

# jqwik database
.jqwik-database

# Environment variables
config/.env

# Tailwind standalone CLI binary (downloaded per-platform)
tailwindcss

# Generated Tailwind CSS output (compiled during build)
src/main/resources/static/css/app.css
src/main/resources/static/css/admin.css

# Accidental CLI output files
amp
zen_generated.code
pal_generated.code
